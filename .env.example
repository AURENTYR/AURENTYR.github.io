# Formspree form ID for the investor/partner contact form (Epic 4 — Lead Capture).
#
# 1. Create a free account at https://formspree.io and add a new form.
# 2. Copy the form's ID from its endpoint URL: https://formspree.io/f/<THIS_PART>
# 3. Copy this file to `.env` and paste the ID below (the .env file is gitignored).
#
# Without this value the contact form falls back to a mailto: link so it never
# silently fails. The free tier allows 50 submissions/month and 1 form.
VITE_FORMSPREE_ID=your_form_id_here

# Email address used for the mailto: fallback when Formspree is not configured
# or a submission errors. Optional.
VITE_CONTACT_EMAIL=hello@aurentyr.com
